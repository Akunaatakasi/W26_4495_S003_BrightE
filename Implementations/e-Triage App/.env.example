# Server
PORT=3001
NODE_ENV=development
# Staff auth: signup and login use the database by default. Set USE_DEMO_AUTH=true only if you want demo login (any email/password, no DB).
# USE_DEMO_AUTH=true

# Database (PostgreSQL)
# Local:
# Supabase: use POOLER URL (port 6543). Do NOT use direct db.xxx.supabase.co:5432 (IPv6, causes ETIMEDOUT).
# DATABASE_URL=postgresql://postgres.[ref]:Akunaatakasi1@aws-0-xx.pooler.supabase.com:6543/postgres
# DATABASE_URL=postgresql://localhost:5432/bright_triage
DATABASE_URL=postgresql://postgres.[ref]:YOUR_PASSWORD@aws-0-xx.pooler.supabase.com:6543/postgres

# JWT (use a long random string in production)
JWT_SECRET=your-secret-key-change-in-production

# Guest triage: days the browser may reload “your request” after submit (default 7, max 30)
# GUEST_CASE_ACCESS_DAYS=7

# Optional: allowed frontend origin for CORS
# CLIENT_ORIGIN=http://localhost:5173

# OTP email (guest triage): without SMTP_HOST, the server does NOT send mail—it only prints the code in the server terminal.
#
# Gmail (use an App Password: Google Account → Security → 2-Step Verification → App passwords):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=you@gmail.com
# SMTP_PASS=your-16-char-app-password
# SMTP_FROM=you@gmail.com
# SMTP_FROM_NAME=e-Triage   # optional friendly "From" name (helps a bit with spam filters)
# OTP_DEBUG_LOG=true        # logs the code to the server console after SMTP accepts—only for local debugging; never in production
#
# SendGrid (SMTP relay): create an API key with Mail Send. Username is always the literal "apikey".
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=apikey
# SMTP_PASS=SG.xxxxxxxxxxxxxxxxxxxxx  # your SendGrid API key
# SMTP_FROM=verified-sender@yourdomain.com   # must be verified in SendGrid
#
# Mailgun (SMTP relay): use the SMTP credentials from Sending → Domain settings (not your Mailgun login).
# US hosts: smtp.mailgun.org — EU: smtp.eu.mailgun.org
# SMTP_HOST=smtp.mailgun.org
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=postmaster@mg.yourdomain.mailgun.org   # or the SMTP login shown in the dashboard
# SMTP_PASS=your-mailgun-smtp-password
# SMTP_FROM=noreply@mg.yourdomain.mailgun.org      # or any authorized sender for that domain
#
# Other providers: match their SMTP docs; use SMTP_SECURE=true on port 465 if required.
